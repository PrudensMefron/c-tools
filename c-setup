#!/usr/bin/env bash
# C-Setup bash script
# Author: PrudensMefron
# Usage: c_setup <path>

set -euo pipefail
IFS=$'\n\t'

readonly RED='\033[0;32m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly NC='\033[0m'

# ----------------------------------------------------
# AUX FUNCTIONS
die() { echo -e "${RED}Error: $*${NC}" >&2; exit 1; }
info() { echo -e "${GREEN}Success: $*${NC}"; }
warn() { echo -e "${YELLOW}Warn: $*${NC}"; }
# ----------------------------------------------------


# ----------------------------------------------------
# PROJECT VARIABLES
PROJECT_NAME=""
PROJECT_DIR=""
USE_MESON=false
USE_CMAKE=false
USE_MAKE=false
USE_GIT=false
USE_CLANG_FORMAT=false
USE_CLANG_TIDY=false
C_STANDARD="c11"
AUTHOR_NAME=""
AUTHOR_EMAIL=""
# ----------------------------------------------------


# ----------------------------------------------------
# GET AUTHOR INFO FROM GIT
get_author_info() {
  local git_name git_email

  git_name=$(git config --local --get user.name 2>/dev/null || true)
  git_email=$(git config --local --get user.email 2>/dev/null || true)

  [[ -z "$git_name" ]] && git_name=$(git config --global --get user.name 2>/dev/null || true)
  [[ -z "$git_email" ]] && git_email=$(git config --global --get user.email 2>/dev/null || true)

  AUTHOR_NAME="${git_name:-}"
  AUTHOR_EMAIL="${git_email:-}"
}
# ----------------------------------------------------

# ----------------------------------------------------
# ASK QUESTIONS
question_loop() {
  
  # Project name
  if [[ $# -eq 1 ]] && [[ -n "$1" ]]; then
    PROJECT_NAME="$1"
  else
    read -rp "Project name: " PROJECT_NAME
  fi
  [[ -z "$PROJECT_NAME" ]] && die "Project name is needed."
  
  PROJECT_DIR="$(pwd)/$PROJECT_NAME"

  if [[ -e "$PROJECT_DIR" && -d "$PROJECT_DIR" ]]; then
    if [[ -n "$(ls -A "$PROJECT_DIR" 2>/dev/null)" ]]; then
      die "The dir '$PROJECT_NAME' already exist and is not empty."
    fi
  fi

  # Build system
  echo -e "\nChoose a build system:"
  select build in "Meson + Ninja (default)" "CMake + Ninja" "Makefile" "All" "None"; do
    case $REPLY in
      1) USE_MESON=true; break;;
      2) USE_CMAKE=true; break;;
      3) USE_MAKE=true; break;;
      4) USE_MESON=true; USE_CMAKE=true; USE_MAKE=true; break;;
      5) break;;
      *) warn "Invalid option. Please, insert a valid one.";;
    esac
  done

  # Git
  read -rp $'\nInitialize a blank Git repository? [Y\N] ' ans
  [[ "$ans" =~ ^([yY]|$) ]] && USE_GIT=true

  # Clang LSP & Formater
  read -rp $'\nAdd .clang-format? (LLVM style) [Y/N] ' ans
  [[ "$ans" =~ ^([yY]|$) ]] && USE_CLANG_FORMAT=true
  
  read -rp $'\nAdd .clang-tidy? [Y/N] ' ans
  [[ "$ans" =~ ^([yY]|$) ]] && USE_CLANG_TIDY=true

  # C standard
  echo -e "\nSelect C standard:"
  select std in "c89" "c99" "c11" "c17" "c23"; do
    C_STANDARD="c${std#c}"
    [[ -n "$C_STANDARD" ]] && break
  done

  get_author_info

  if [[ -z "$AUTHOR_NAME" && -z "$AUTHOR_EMAIL" ]]; then
    info "Author detected from Git: $AUTHOR_NAME <$AUTHOR_EMAIL>"
    read -rp $'Use this author name and email? [Y/N] ' ans
    if [[ "$ans" =~ ^[yY]$ ]]; then
      read -rp $'New author name: ' AUTHOR_NAME
      read -rp $'New author email: ' AUTHOR_EMAIL
    fi
  else
    warn "Author name and email not detected on Git."
    read -rp $'Your name (for copyright): ' AUTHOR_NAME
    read -rp $'Your email: ' AUTHOR_EMAIL
  fi
}
# ----------------------------------------------------


# ----------------------------------------------------
# FOLDER STRUCTURE
create_structure() {
  info "Creating dir structures in $PROJECT_DIR"
  mkdir -p "$PROJECT_DIR"/{src,include,tests,build,docs,external}

  cat > "$PROJECT_DIR/README.md" <<EOF
# $PROJECT_NAME

Description of the project.

## Build

\`\`\`bash
EOF

  if $USE_MESON; then
    cat >> "$PROJECT_DIR/README.md" <<EOF
meson setup builddir
meson compile -C builddir
EOF
  elif $USE_CMAKE; then
    cat >> "$PROJECT_DIR/README.md" <<EOF
cmake -B build -G Ninja . # Only the first time or if you change the CMakeLists.txt
cmake --build build
EOF
  elif $USE_MAKE; then
    echo "make" >> "$PROJECT_DIR/README.md"
  fi

  echo "\`\`\`" >> "$PROJECT_DIR/README.md"

  cat >> "$PROJECT_DIR/README.md" <<EOF
## Autor
$AUTHOR_NAME <$AUTHOR_EMAIL>
EOF
  
  touch "$PROJECT_DIR/.gitignore"
  cat > "$PROJECT_DIR/.gitignore" <<EOF
build/
builddir/
*.o
*.a
*.so
*.exe
.vscode/
.idea/
.zed/
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
compile_commands.json
# Meson build directories
meson-private/
meson-logs/
EOF
}
# ----------------------------------------------------

# ----------------------------------------------------
# MAKEFILE CONFIG
create_makefile() {
  info "Generating Makefile"
  cat > "$PROJECT_DIR/Makefile" <<EOF
# Variables
CC := gcc
CFLAGS := -Wall -Wextra -Wpedantic -std=$C_STANDARD -Iinclude
LDFLAGS :=
SRC := src
OBJ := obj
BIN := bin
TARGET := $PROJECT_NAME

SOURCES := \$(wildcard \$(src)/.*.c)
OBJECTS := \$(SOURCES:\$(SRC)/%.c=\$(OBJ)/%.o)

.PHONY: all clean run debug

all: \$(BIN)/\$(TARGET)
\$(BIN)/\$(TARGET): $(OBJECTS) | \$(BIN)
  \$(CC) \$(LDFLAGS) -o \$@ \$^

\$(OBJ)/%.o: \$(SRC)/%.c | \$(OBJ)
  \$(CC) \$(CFLAGS) -c \$< -o \$@

\$(BIN) \$(OBJ):
  mkdir -p \$@

clean:
  rm -rf \$(OBJ) \$(BIN)

run: all
  ./\$(BIN)/\$(TARGET)

debug: CFLAGS += -g -O0
debug: all
  gdb \$(BIN)/\$(TARGET)
EOF
  
  mkdir -p "$PROJECT_DIR"/{obj,bin}
}
# ----------------------------------------------------

# ----------------------------------------------------
# CMakeLists.txt SETUP
create_cmake() {
  info "Generating CMakeLists.txt with Ninja configs"
  cat > "$PROJECT_DIR/CMakeLists.txt" <<EOF
cmake_minimum_required(VERSION 3.16)
project($PROJECT_NAME LANGUAGES C VERSION 1.0.0)

set(CMAKE_C_STANDARD $C_STANDARD)
set(CMAKE_C_STANDARD_REQUIRED ON)
set(CMAKE_C_EXTENSIONS OFF)

set(CMAKE_EXPORT_COMPILE_COMMANDS ON)

add_compile_options(-Wall -Wextra -Wpedantic)

# Main target
file(GLOB_RECURSE SOURCES "src/*.c")
add_executable(\${PROJECT_NAME} \${SOURCES})
target_include_directories(\${PROJECT_NAME} PRIVATE include)

# Link compile_commands.json with root
add_custom_command(TARGET \${PROJECT_NAME} POST_BUILD
  COMMAND \${CMAKE_COMMAND} -E copy_if_different
    \${CMAKE_BINARY_DIR}/compile_commands.json
    \${CMAKE_SOURCE_DIR}/compile_commands.json
)

# Tests (OPTIONAL - using CTest + Unity or CMockery)
option(ENABLE_TESTS "Enable tests compilation" OFF)
IF(ENABLE_TESTS)
  enable_testing()
  add_subdirectory(tests)
endif()
EOF
}
# ----------------------------------------------------

# ----------------------------------------------------
# MESON BUILD SETUP
create_meson() {
  info "Generating meson.build"
  cat > "$PROJECT_DIR/meson.build" <<EOF
project('$PROJECT_NAME', 'c',
  version: '1.0.0',
  default_options: [
    'warning_level=3',
    'c_std=$C_STANDARD'
  ]
)

executable(
  '$PROJECT_NAME',
  sources: files('src/main.c'),
  include_directories: include_directories('include'),
  install: true,
)

# Enable tests if requested
option('enable_tests', type: 'boolean', value: false, description: 'Enable tests compilation')

if get_option('enable_tests')
  subdir('tests')
endif
EOF
}
# ----------------------------------------------------

# ----------------------------------------------------
# .clang-format SETUP (CUSTOM RULES)
create_clang_format() {
  info "Generating .clang-format"
  cat > "$PROJECT_DIR/.clang-format" <<EOF
---
BasedOnStyle: GNU
IndentWidth: 4
ColumnLimit: 80

# --- Regras de Espaçamento antes de Parênteses ---
# Garante o espaço em: if (, while (, chamadas de função e declarações.
SpaceBeforeParens: Custom
SpaceBeforeParensOptions:
  AfterControlStatements: true
  AfterFunctionDeclarationName: true
  AfterFunctionDefinitionName: true
  AfterIfMacros: true
  AfterOverloadedOperator: true
  BeforeNonEmptyParentheses: true

# --- Padrão GNU de Quebra de Linha ---
AlwaysBreakAfterReturnType: AllDefinitions
BreakBeforeBraces: Custom
BraceWrapping:
  AfterControlStatement: MultiLine # Permite '{' na mesma linha se o if for simples, ou segue GNU se complexo
  AfterFunction: true # A chave sempre quebra linha após a função (Padrão GNU)
  BeforeElse: false
  AfterStruct: true
  AfterEnum: true

# --- Alinhamento de Parâmetros Longos ---
# Impede que o clang-format tente "empacotar" muitos parâmetros na mesma linha
BinPackParameters: false
AlignAfterOpenBracket: Align

# --- Alinhamento de Atribuições e Declarações ---
AlignConsecutiveAssignments:
  Enabled: true
  AcrossEmptyLines: false
  AcrossComments: false

AlignConsecutiveDeclarations:
  Enabled: true

AlignTrailingComments:
  Kind: Always
  OverEmptyLines: 1

# Garante que o '*' fique junto ao nome: int *ptr
PointerAlignment: Right
EOF
}
# ----------------------------------------------------

# ----------------------------------------------------
# .clang-tidy SETUP (BASED ON LLVM)
create_clang_tidy() {
  info "Generating .clang-tidy"
  cat > "$PROJECT_DIR/.clang-tidy" <<EOF
Checks: >
  bugprone-*,
  clang-analyzer-*,
  cppcoreguidelines-*,
  modernize-*,
  performance-*,
  portability-*,
  readability-*
WarningsAsErrors: ''
HeaderFilterRegex: '.*'
FormatStyle: file
CheckOptions:
  - key:             readability-braces-around-statements.ShortStatementLines
    value:           camelCase
EOF
}
# ----------------------------------------------------

# ----------------------------------------------------
# INITAL main.c FILE
create_main() {
  info "Generating main.c"
  cat > "$PROJECT_DIR/src/main.c" <<EOF
#include <stdio.h>

int main(int argc, char *argv[])
{
  (void)argc;
  (void)argv;

  printf("Olá, $PROJECT_NAME!\\n");
  return 0;
}
EOF
}
# ----------------------------------------------------

# ----------------------------------------------------
# GIT INIT
git_init() {
  if $USE_GIT; then
    info "Initializing Git repository"
    (cd "$PROJECT_DIR" && git init)
  fi
}
# ----------------------------------------------------

# ----------------------------------------------------
# MAIN
main() {
  echo -e "${GREEN}=== C Project Setup ===${NC}\n"
  question_loop "$@"

  create_structure

  $USE_MESON && create_meson
  $USE_MAKE && create_makefile
  $USE_CMAKE && create_cmake
  $USE_CLANG_FORMAT && create_clang_format
  $USE_CLANG_TIDY && create_clang_tidy
  
  create_main
  git_init

  info "Project $PROJECT_NAME created successfully in:"
  echo "        $PROJECT_DIR"
  echo
  echo "Next steps:"
  if $USE_MESON; then
    echo "        cd $PROJECT_NAME"
    echo "        meson setup builddir"
    echo "        meson compile -C builddir"
    echo
    echo "        ./builddir/$PROJECT_NAME"
  elif $USE_CMAKE; then
    echo "        cd $PROJECT_NAME"
    echo "        cmake -B build -G Ninja ."
    echo "        cmake --build build"
    echo
    echo "        ./build/$PROJECT_NAME"
  elif $USE_MAKE; then
    echo "        cd $PROJECT_NAME && make"
  fi
  echo
}
# ----------------------------------------------------

# ENTRY POINT
main "$@"
