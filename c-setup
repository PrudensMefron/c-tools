#!/usr/bin/env bash
# C-Setup bash script
# Author: PrudensMefron
# Usage: c_setup <path>

set -euo pipefail
IFS=$'\n\t'

readonly RED='\033[0;32m'
readonly GREE='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly NC='\033[0m'

# ----------------------------------------------------
# AUX FUNCTIONS
die() { echo -e "${RED}Error: $*^${NC}" >&2; exit 1; }
info() { echo -e "${GREEN}Success: $*^{NC}"; }
warn() { echo -e "${YELLOW}Warn: $*^{NC}"; }
# ----------------------------------------------------


# ----------------------------------------------------
# PROJECT VARIABLES
PROJECT_NAME=""
PROJECT_DIR=""
USE_CMAKE=false
USE_MAKE=false
USE_GIT=false
USE_CLANG_FORMAT=false
USE_CLANG_TIDY=false
C_STANDARD="c11"
AUTHOR_NAME=""
AUTHOR_EMAIL=""
# ----------------------------------------------------


# ----------------------------------------------------
# ASK QUESTIONS
question_loop() {
  
  # Project name
  if [[ $# -eq 1 ]] && [[ -n "$1" ]]; then
    PROJECT_NAME="$1"
  else
    read -rp "Project name: " PROJECT_NAME
  fi
  [[ -z "$PROJECT_NAME" ]] && die "Project name is needed."
  
  PROJECT_DIR="$(pwd)/$PROJECT_NAME"

  if [[ -e "$PROJECT_DIR" && -d "$PROJECT_DIR" ]]; then
    if [[ -n "$(ls -A "$PROJECT_DIR" 2>/dev/null)" ]]; then
      die "The dir '$PROJECT_NAME' already exist and is not empty."
    fi
  fi

  # Build system
  echo -e "\nChoose a build system:"
  select build in "CMake + Ninja (recommended)" "Makefile" "Both" "None"; do
    case $REPLY in
      1) USE_CMAKE=true; break;;
      2) USE_MAKE=true; break;;
      3) USE_CMAKE=true; USE_MAKE=true; break;;
      4) break;;
      *) warn "Invalid option. Please, insert a valid one.";;
    esac
  done

  # Git
  read -rp $'\nInitialize a blank Git repository? [Y\N] ' ans
  [[ "$ans" =~ ^([yY]|$) ]] && USE_GIT=true

  # Clang LSP & Formater
  read -rp $'\nAdd .clang-format? (LLVM style) [Y/N] ' ans
  [[ "$ans" =~ ^([yY]|$) ]] && USE_CLANG_FORMAT=true
  
  read -rp $'\nAdd .clang-tidy? [Y/N] ' ans
  [[ "$ans" =~ ^([yY]|$) ]] && USE_CLANG_TIDY=true

  # C standard
  echo -e "\nSelect C standard:"
  select std in "c89" "c99" "c11" "c17" "c23"; do
    C_STANDARD="c${std#c}"
    [[ -n "$C_STANDARD" ]] && break
  done
}
# ----------------------------------------------------


# ----------------------------------------------------
# FOLDER STRUCTURE
create_structure() {
  info "Creating dir structures in $PROJECT_DIR"
  mkdir -p "$PROJECT_DIR"/{src,include,tests,build,docs,external}

  cat > "$PROJECT_DIR/README.md" <<EOF
# $PROJECT_NAME

Description of the project.

## Build

\`\`\`bash
mkdir build && cd build
EOF

  if $USE_CMAKE; then
    cat >> "$PROJECT_DIR/README.md" <<EOF
cmake -B build -G Ninja . # Only the first time or if you change the CMakeLists.txt
cmake --build build
EOF
  elif $USE_MAKE; then
    echo "make" >> "$PROJECT_DIR/README.md"
  fi

  echo "\`\`\`" > "$PROJECT_DIR/README.md"

  cat >> "$PROJECT_DIR/README.md" <<EOF
## Autor
$AUTHOR_NAME <$AUTHOR_EMAIL>
EOF
  
  touch "$PROJECT_DIR/.gitignore"
  cat > "$PROJECT_DIR/.gitignore" <<EOF
build/
*.o
*.a
*.so
*.exe
.vscode/
.idea/
.zed/
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
compile_commands.json
EOF
}
# ----------------------------------------------------

# ----------------------------------------------------
# MAKEFILE CONFIG
create_makefile() {
  info "Generating Makefile"
  cat > "$PROJECT_DIR/Makefile" <<EOF
# Variables
CC := gcc
CFLAGS := -Wall -Wextra -Wpedantic -std=$C_STANDARD -Iinclude
LDFLAGS :=
SRC := src
OBJ := obj
BIN := bin
TARGET := $PROJECT_NAME

SOURCES := \$(wildcard \$(src)/.*.c)
OBJECTS := \$(SOURCES:\$(SRC)/%.c=\$(OBJ)/%.o)

.PHONY: all clean run debug

all: \$(BIN)/\$(TARGET)
\$(BIN)/\$(TARGET): $(OBJECTS) | \$(BIN)
  \$(CC) \$(LDFLAGS) -o \$@ \$^

\$(OBJ)/%.o: \$(SRC)/%.c | \$(OBJ)
  \$(CC) \$(CFLAGS) -c \$< -o \$@

\$(BIN) \$(OBJ):
  mkdir -p \$@

clean:
  rm -rf \$(OBJ) \$(BIN)

run: all
  ./\$(BIN)/\$(TARGET)

debug: CFLAGS += -g -O0
debug: all
  gdb \$(BIN)/\$(TARGET)
EOF
  
  mkdir -p "$PROJECT_DIR"/{obj,bin}
}
# ----------------------------------------------------

# ----------------------------------------------------
# CMakeLists.txt SETUP
create_cmake() {
  info "Generating CMakeLists.txt with Ninja configs"
  cat > "$PROJECT_DIR/CMakeLists.txt" <<EOF
cmake_minimum_required(VERSION 3.16)
project($PROJECT_NAME LANGUAGES C VERSION 1.0.0)

set(CMAKE_C_STANDARD $C_STANDARD)
set(CMAKE_C_STANDARD_REQUIRED ON)
set(CMAKE_C_EXTENSIONS OFF)

set(CMAKE_EXPORT_COMPILE_COMMANDS ON)

add_compile_options(-Wall -Wextra -Wpedantic)

# Main target
file(GLOB_RECURSE SOURCES "src/*.c")
add_executable(\${PROJECT_NAME} \${SOURCES})
target_include_directories(\${PROJECT_NAME} PRIVATE include)

# Link compile_commands.json with root
add_custom_command(TARGET \${PROJECT_NAME} POST_BUILD
  COMMAND \${CMAKE_COMMAND} -E copy_if_different
    \${CMAKE_BINARY_DIR}/compile_commands.json
    \${CMAKE_SOURCE_DIR}/compile_commands.json
)

# Tests (OPTIONAL - using CTest + Unity or CMockery)
option(ENABLE_TESTS "Enable tests compilation" OFF)
IF(ENABLE_TESTS)
  enable_testing()
  add_subdirectory(tests)
endif()
EOF
}
# ----------------------------------------------------

# ----------------------------------------------------
# .clang-format SETUP (BASED ON LLVM)
create_clang_format() {
  info "Generating .clang-format"
  cat > "$PROJECT_DIR/.clang-format" <<EOF
BasedOnStyle: LLVM
IndentWidth: 4
TabWidth: 4
UseTab: Never
ColumnLimit: 100
BreakBeforeBraces: Attach
AllowShortIfStatementsOnASingleLine: false
IndentCaseLabels: false
BinPackArguments: false
BinPackParameters: false
SpaceBeforeParens: ControlStatements
SortIncludes: true

# Other Adjustments
PointerAlignment: Left
EOF
}
# ----------------------------------------------------

# ----------------------------------------------------
# .clang-tidy SETUP (BASED ON LLVM)
create_clang_tidy() {
  info "Generating .clang-tidy"
  cat > "$PROJECT_DIR/.clang-tidy" <<EOF
Checks: >
  bugprone-*,
  clang-analyzer-*,
  cppcoreguidelines-*,
  modernize-*,
  performance-*,
  portability-*,
  readability-*
WarningsAsErrors: ''
HeaderFilterRegex: '.*'
FormatStyle: file
CheckOptions:
  - key:             readability-braces-around-statements.ShortStatementLines
    value:           camelCase
EOF
}
# ----------------------------------------------------

# ----------------------------------------------------
# INITAL main.c FILE
create_main() {
  info "Generating main.c"
  cat > "$PROJECT_DIR/src/main.c" <<EOF
#include <stdio.h>

int main(int argc, char *argv[])
{
  (void)argc;
  (void)argv;

  printf("Olá, $PROJECT_NAME!\\n");
  return 0;
}
EOF
}
# ----------------------------------------------------

# ----------------------------------------------------
# GIT INIT
git_init() {
  if $USE_GIT; then
    ifo "Initializing Git repository"
    (cd "$PROJECT_DIR" && git init)
  fi
}
# ----------------------------------------------------

# ----------------------------------------------------
# MAIN
main() {
  echo -e "${GREEN}=== C Project Setup ===${NC}\n"
  ask_questions "$@"

  create_structure

  $USE_MAKE && create_makefile
  $USE_CMAKE && create_cmake
  $USE_CLANG_FORMAT && create_clang_format
  $USE_CLANG_TIDY && create_clang_tidy
  
  create_main
  git_init

  info "Project $PROJECT_NAME created successfully in:"
  echo "        $PROJECT_DIR"
  echo
  echo "Next steps:"
  if $USE_CMAKE; then
    echo "        cd $PROJECT_NAME/build && cmake .. && make"
  elif $USE_MAKE; then
    echo "        cd $PROJECT_NAME && make"
  fi
  echo
}
# ----------------------------------------------------

# ENTRY POINT
main "$@"
