#!/usr/bin/env bash
# C/C++-Setup bash script
# Author: PrudensMefron
# Usage: c_setup [options] [project_name]

set -euo pipefail
IFS=$'\n\t'

readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly NC='\033[0m'

# ----------------------------------------------------
# CONFIGURATION TEMPLATES (Organized for easy modification)

# --- CLANG-FORMAT ---
CLANG_FORMAT_C='---
BasedOnStyle: GNU
IndentWidth: 4
ColumnLimit: 80
SpaceBeforeParens: Custom
SpaceBeforeParensOptions:
  AfterControlStatements: true
  AfterFunctionDeclarationName: true
  AfterFunctionDefinitionName: true
  AfterIfMacros: true
  AfterOverloadedOperator: true
  BeforeNonEmptyParentheses: true
AlwaysBreakAfterReturnType: AllDefinitions
BreakBeforeBraces: Custom
BraceWrapping:
  AfterControlStatement: MultiLine
  AfterFunction: true
  BeforeElse: false
  AfterStruct: true
  AfterEnum: true
BinPackParameters: false
AlignAfterOpenBracket: Align
AlignConsecutiveAssignments:
  Enabled: true
  AcrossEmptyLines: false
  AcrossComments: false
AlignConsecutiveDeclarations:
  Enabled: true
AlignTrailingComments:
  Kind: Always
  OverEmptyLines: 1
PointerAlignment: Right
'

CLANG_FORMAT_CPP='---
BasedOnStyle: LLVM
IndentWidth: 4
ColumnLimit: 100
BreakBeforeBraces: Allman
AllowShortFunctionsOnASingleLine: None
NamespaceIndentation: All
'

# --- CLANG-TIDY ---
CLANG_TIDY_BASE='Checks: >
  bugprone-*,
  clang-analyzer-*,
  cppcoreguidelines-*,
  modernize-*,
  performance-*,
  portability-*,
  readability-*
WarningsAsErrors: ""
HeaderFilterRegex: ".*"
FormatStyle: file
'

# --- MESON TEMPLATES ---
MESON_ROOT_BASE="project('{PROJECT_NAME}', {LANG_LIST},
  version: '1.0.0',
  default_options: [
    'warning_level=3',
    {STD_OPTIONS}
  ]
)

subdir('src')"

MESON_SRC_BASE="executable(
  '{PROJECT_NAME}',
  sources: files({SOURCES}),
  include_directories: include_directories('../include'),
  install: true,
)"

# --- CMAKE TEMPLATE ---
CMAKE_BASE='cmake_minimum_required(VERSION 3.16)
project({PROJECT_NAME} LANGUAGES {LANG_LIST} VERSION 1.0.0)

{STD_CONFIG}

set(CMAKE_EXPORT_COMPILE_COMMANDS ON)
add_compile_options(-Wall -Wextra -Wpedantic)

file(GLOB_RECURSE SOURCES "src/*.c" "src/*.cpp")
add_executable(${PROJECT_NAME} ${SOURCES})
target_include_directories(${PROJECT_NAME} PRIVATE include)
'

# --- MAKEFILE TEMPLATE ---
MAKEFILE_BASE='CC := {CC}
CXX := {CXX}
CFLAGS := -Wall -Wextra -Wpedantic {C_STD} -Iinclude
CXXFLAGS := -Wall -Wextra -Wpedantic {CPP_STD} -Iinclude
LDFLAGS :=
SRC := src
OBJ := obj
BIN := bin
TARGET := {PROJECT_NAME}

SOURCES := $(wildcard $(SRC)/*.c) $(wildcard $(SRC)/*.cpp)
OBJECTS := $(patsubst $(SRC)/%.c,$(OBJ)/%.o,$(patsubst $(SRC)/%.cpp,$(OBJ)/%.o,$(SOURCES)))

.PHONY: all clean run debug

all: $(BIN)/$(TARGET)

$(BIN)/$(TARGET): $(OBJECTS) | $(BIN)
	$(CC) $(LDFLAGS) -o $@ $^

$(OBJ)/%.o: $(SRC)/%.c | $(OBJ)
	$(CC) $(CFLAGS) -c $< -o $@

$(OBJ)/%.o: $(SRC)/%.cpp | $(OBJ)
	$(CXX) $(CXXFLAGS) -c $< -o $@

$(BIN) $(OBJ):
	mkdir -p $@

clean:
	rm -rf $(OBJ) $(BIN)

run: all
	./$(BIN)/$(TARGET)
'

# --- MAIN FILES ---
MAIN_C='#include <stdio.h>

int main(int argc, char *argv[])
{
    (void)argc;
    (void)argv;
    printf("Hello from C project: {PROJECT_NAME}!\\n");
    return 0;
}
'

MAIN_CPP='#include <iostream>

int main(int argc, char *argv[])
{
    (void)argc;
    (void)argv;
    std::cout << "Hello from C++ project: {PROJECT_NAME}!" << std::endl;
    return 0;
}
'

# ----------------------------------------------------
# PROJECT STATE VARIABLES
PROJECT_NAME=""
PROJECT_DIR=""
LANG_CHOICE="" # "c", "cpp", "both"
USE_MESON=false
USE_CMAKE=false
USE_MAKE=false
USE_GIT=false
USE_CLANG_FORMAT=false
USE_CLANG_TIDY=false
C_STANDARD="c11"
CPP_STANDARD="c++17"
AUTHOR_NAME=""
AUTHOR_EMAIL=""

# PIPELINE FLAGS
FLAG_BUILD_ONLY=false
FLAG_LANG_ONLY=false
FLAG_GIT_ONLY=false
FLAG_FORMAT_ONLY=false
FLAG_FULL_SETUP=true
# ----------------------------------------------------

# ----------------------------------------------------
# AUX FUNCTIONS
die() { echo -e "${RED}Error: $*${NC}" >&2; exit 1; }
info() { echo -e "${GREEN}Success: $*${NC}"; }
warn() { echo -e "${YELLOW}Warn: $*${NC}"; }


# ----------------------------------------------------
# GET AUTHOR INFO FROM GIT
get_author_info() {
  local git_name git_email

  git_name=$(git config --local --get user.name 2>/dev/null || true)
  git_email=$(git config --local --get user.email 2>/dev/null || true)

  [[ -z "$git_name" ]] && git_name=$(git config --global --get user.name 2>/dev/null || true)
  [[ -z "$git_email" ]] && git_email=$(git config --global --get user.email 2>/dev/null || true)

  AUTHOR_NAME="${git_name:-}"
  AUTHOR_EMAIL="${git_email:-}"
}

# ----------------------------------------------------
# MODULAR QUESTIONS

ask_language() {
  [[ -n "$LANG_CHOICE" ]] && return
  echo -e "\nChoose language:"
  select opt in "C" "C++" "Both (C & C++)"; do
    case $REPLY in
      1) LANG_CHOICE="c"; break;;
      2) LANG_CHOICE="cpp"; break;;
      3) LANG_CHOICE="both"; break;;
      *) warn "Invalid option.";;
    esac
  done
}

ask_build_system() {
  echo -e "\nChoose a build system:"
  select build in "Meson + Ninja (default)" "CMake + Ninja" "Makefile" "All" "None"; do
    case $REPLY in
      1) USE_MESON=true; break;;
      2) USE_CMAKE=true; break;;
      3) USE_MAKE=true; break;;
      4) USE_MESON=true; USE_CMAKE=true; USE_MAKE=true; break;;
      5) break;;
      *) warn "Invalid option.";;
    esac
  done
}

ask_git() {
  read -rp $'\nInitialize a blank Git repository? [Y/N] ' ans
  [[ "$ans" =~ ^([yY]|$) ]] && USE_GIT=true
}

ask_format() {
  read -rp $'\nAdd .clang-format? [Y/N] ' ans
  [[ "$ans" =~ ^([yY]|$) ]] && USE_CLANG_FORMAT=true
  
  read -rp $'\nAdd .clang-tidy? [Y/N] ' ans
  [[ "$ans" =~ ^([yY]|$) ]] && USE_CLANG_TIDY=true
}

ask_standards() {
  if [[ "$LANG_CHOICE" == "c" || "$LANG_CHOICE" == "both" ]]; then
    echo -e "\nSelect C standard:"
    select std in "c89" "c99" "c11" "c17" "c23"; do
      C_STANDARD="c${std#c}"; [[ -n "$C_STANDARD" ]] && break
    done
  fi
  if [[ "$LANG_CHOICE" == "cpp" || "$LANG_CHOICE" == "both" ]]; then
    echo -e "\nSelect C++ standard:"
    select std in "c++11" "c++14" "c++17" "c++20" "c++23"; do
      CPP_STANDARD="${std}"; [[ -n "$CPP_STANDARD" ]] && break
    done
  fi
}

ask_author() {
  get_author_info
  if [[ -n "$AUTHOR_NAME" ]]; then
    info "Author detected: $AUTHOR_NAME <$AUTHOR_EMAIL>"
    read -rp $'Use this author info? [Y/N] ' ans
    if [[ ! "$ans" =~ ^([yY]|$) ]]; then
      read -rp $'New author name: ' AUTHOR_NAME
      read -rp $'New author email: ' AUTHOR_EMAIL
    fi
  else
    warn "Author info not detected."
    read -rp $'Your name: ' AUTHOR_NAME
    read -rp $'Your email: ' AUTHOR_EMAIL
  fi
}

# ----------------------------------------------------
# USAGE
usage() {
  echo "Usage: c_setup [options] [project_name]"
  echo "Options:"
  echo "  -b, --build   Setup only the build system (Meson, CMake, or Makefile)"
  echo "  -l, --lang    Setup only the language (C, C++, or both) and main file"
  echo "  -g, --git     Initialize a Git repository only"
  echo "  -f, --format  Setup Clang-format and Clang-tidy only"
  echo "  -h, --help    Show this help message"
  echo ""
  echo "If no options are provided, a full interactive setup will run."
  exit 0
}

# ----------------------------------------------------
# ARGUMENT PARSING
parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -b|--build) FLAG_BUILD_ONLY=true; FLAG_FULL_SETUP=false; shift ;;
      -l|--lang) 
        if [[ -n "${2:-}" && ! "$2" =~ ^- ]]; then
          LANG_CHOICE="$2"; shift 2
        else
          FLAG_LANG_ONLY=true; FLAG_FULL_SETUP=false; shift
        fi
        ;;
      -g|--git) FLAG_GIT_ONLY=true; FLAG_FULL_SETUP=false; shift ;;
      -f|--format) FLAG_FORMAT_ONLY=true; FLAG_FULL_SETUP=false; shift ;;
      -h|--help) usage ;;
      -*) die "Unknown option: $1. Use -h for help." ;;
      *) 
        if [[ -z "$PROJECT_NAME" ]]; then
          PROJECT_NAME="$1"
          shift
        else
          die "Multiple project names provided: $PROJECT_NAME and $1"
        fi
        ;;
    esac
  done

  # Project name/directory logic
  if [[ -z "$PROJECT_NAME" ]]; then
    if $FLAG_FULL_SETUP; then
      read -rp "Project name: " PROJECT_NAME
      [[ -z "$PROJECT_NAME" ]] && die "Project name is required."
    else
      PROJECT_NAME=$(basename "$(pwd)")
    fi
  fi

  if [[ "$PROJECT_NAME" == "$(basename "$(pwd)")" ]]; then
    PROJECT_DIR="$(pwd)"
  else
    PROJECT_DIR="$(pwd)/$PROJECT_NAME"
    if [[ -d "$PROJECT_DIR" && -n "$(ls -A "$PROJECT_DIR" 2>/dev/null)" ]]; then
        die "Directory '$PROJECT_NAME' already exists and is not empty."
    fi
  fi
}
# ----------------------------------------------------


# ----------------------------------------------------
# FILE CREATION HELPERS
create_structure() {
  info "Creating directory structure in $PROJECT_DIR"
  mkdir -p "$PROJECT_DIR"/{src,include,tests,build,docs,external}

  cat > "$PROJECT_DIR/README.md" <<EOF
# $PROJECT_NAME
Created by $AUTHOR_NAME <$AUTHOR_EMAIL>

## Build Instructions
EOF

  if $USE_MESON; then
    cat >> "$PROJECT_DIR/README.md" <<EOF
\`\`\`bash
meson setup builddir
meson compile -C builddir
./builddir/$PROJECT_NAME
\`\`\`
EOF
  fi

  cat >> "$PROJECT_DIR/.gitignore" <<EOF
build/
builddir/
*.o
*.a
*.so
*.exe
.vscode/
.idea/
.zed/
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
compile_commands.json
meson-private/
meson-logs/
EOF
}

create_makefile() {
  info "Generating Makefile"
  local cc="gcc" cxx="g++"
  [[ "$LANG_CHOICE" == "cpp" ]] && cc="g++"
  
  local content="$MAKEFILE_BASE"
  content="${content//{PROJECT_NAME\}/$PROJECT_NAME}"
  content="${content//{CC\}/$cc}"
  content="${content//{CXX\}/$cxx}"
  content="${content//{C_STD\}/-std=$C_STANDARD}"
  content="${content//{CPP_STD\}/-std=$CPP_STANDARD}"
  echo "$content" > "$PROJECT_DIR/Makefile"
  mkdir -p "$PROJECT_DIR"/{obj,bin}
}

create_cmake() {
  info "Generating CMakeLists.txt"
  local lang_list="C"
  [[ "$LANG_CHOICE" == "cpp" ]] && lang_list="CXX"
  [[ "$LANG_CHOICE" == "both" ]] && lang_list="C CXX"

  local std_config="set(CMAKE_C_STANDARD ${C_STANDARD#c})\nset(CMAKE_C_STANDARD_REQUIRED ON)"
  [[ "$LANG_CHOICE" == "cpp" ]] && std_config="set(CMAKE_CXX_STANDARD ${CPP_STANDARD#c++})\nset(CMAKE_CXX_STANDARD_REQUIRED ON)"
  [[ "$LANG_CHOICE" == "both" ]] && std_config="set(CMAKE_C_STANDARD ${C_STANDARD#c})\nset(CMAKE_CXX_STANDARD ${CPP_STANDARD#c++})\nset(CMAKE_C_STANDARD_REQUIRED ON)\nset(CMAKE_CXX_STANDARD_REQUIRED ON)"

  local content="$CMAKE_BASE"
  content="${content//{PROJECT_NAME\}/$PROJECT_NAME}"
  content="${content//{LANG_LIST\}/$lang_list}"
  content="${content//{STD_CONFIG\}/$std_config}"
  echo -e "$content" > "$PROJECT_DIR/CMakeLists.txt"
}

create_meson() {
  info "Generating Meson build files"
  local lang_list="'c'"
  local std_opts="'c_std=$C_STANDARD'"
  local sources="'main.c'"

  if [[ "$LANG_CHOICE" == "cpp" ]]; then
    lang_list="'cpp'"
    std_opts="'cpp_std=$CPP_STANDARD'"
    sources="'main.cpp'"
  elif [[ "$LANG_CHOICE" == "both" ]]; then
    lang_list="'c', 'cpp'"
    std_opts="'c_std=$C_STANDARD', 'cpp_std=$CPP_STANDARD'"
    sources="'main.cpp'" # Default entry for both is .cpp
  fi

  # Root meson.build
  local root_content="$MESON_ROOT_BASE"
  root_content="${root_content//{PROJECT_NAME\}/$PROJECT_NAME}"
  root_content="${root_content//{LANG_LIST\}/$lang_list}"
  root_content="${root_content//{STD_OPTIONS\}/$std_opts}"
  echo "$root_content" > "$PROJECT_DIR/meson.build"

  # src/meson.build
  local src_content="$MESON_SRC_BASE"
  src_content="${src_content//{PROJECT_NAME\}/$PROJECT_NAME}"
  src_content="${src_content//{SOURCES\}/$sources}"
  echo "$src_content" > "$PROJECT_DIR/src/meson.build"
}

create_clang_format() {
  info "Generating .clang-format"
  local content="$CLANG_FORMAT_C"
  # Use C++ style (Allman) if project includes C++
  [[ "$LANG_CHOICE" == "cpp" || "$LANG_CHOICE" == "both" ]] && content="$CLANG_FORMAT_CPP"
  echo "$content" > "$PROJECT_DIR/.clang-format"
}

create_clang_tidy() {
  info "Generating .clang-tidy"
  echo "$CLANG_TIDY_BASE" > "$PROJECT_DIR/.clang-tidy"
}

create_main() {
  info "Generating source files"
  if [[ "$LANG_CHOICE" == "c" ]]; then
    local content="${MAIN_C//{PROJECT_NAME\}/$PROJECT_NAME}"
    echo "$content" > "$PROJECT_DIR/src/main.c"
  elif [[ "$LANG_CHOICE" == "cpp" ]]; then
    local content="${MAIN_CPP//{PROJECT_NAME\}/$PROJECT_NAME}"
    echo "$content" > "$PROJECT_DIR/src/main.cpp"
  elif [[ "$LANG_CHOICE" == "both" ]]; then
    local content_cpp="${MAIN_CPP//{PROJECT_NAME\}/$PROJECT_NAME}"
    echo "$content_cpp" > "$PROJECT_DIR/src/main.cpp"
  fi
}
# ----------------------------------------------------

# ----------------------------------------------------
# GIT INIT
git_init() {
  if $USE_GIT; then
    info "Initializing Git repository in $PROJECT_DIR"
    (cd "$PROJECT_DIR" && git init)
  fi
}

# ----------------------------------------------------
# PIPELINES
pipeline_full() {
  ask_language
  ask_build_system
  ask_git
  ask_format
  ask_standards
  ask_author

  create_structure
  $USE_MESON && create_meson
  $USE_MAKE && create_makefile
  $USE_CMAKE && create_cmake
  $USE_CLANG_FORMAT && create_clang_format
  $USE_CLANG_TIDY && create_clang_tidy
  
  create_main
  git_init
}

pipeline_build() {
  ask_language
  ask_build_system
  mkdir -p "$PROJECT_DIR"/{src,include}
  $USE_MESON && create_meson
  $USE_MAKE && create_makefile
  $USE_CMAKE && create_cmake
}

pipeline_format() {
  ask_language
  ask_format
  mkdir -p "$PROJECT_DIR"
  $USE_CLANG_FORMAT && create_clang_format
  $USE_CLANG_TIDY && create_clang_tidy
}

pipeline_lang() {
  ask_language
  mkdir -p "$PROJECT_DIR/src"
  create_main
}

# ----------------------------------------------------
# MAIN
main() {
  parse_args "$@"

  echo -e "${GREEN}=== C/C++ Project Setup ===${NC}\n"

  if $FLAG_FULL_SETUP; then
    pipeline_full
  else
    if $FLAG_BUILD_ONLY; then pipeline_build; fi
    if $FLAG_LANG_ONLY; then pipeline_lang; fi
    if $FLAG_GIT_ONLY; then USE_GIT=true; git_init; fi
    if $FLAG_FORMAT_ONLY; then pipeline_format; fi
  fi

  info "Project operation completed successfully."
  echo "Location: $PROJECT_DIR"
}

# ENTRY POINT
main "$@"
